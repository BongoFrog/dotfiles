{
  "layer": "top",
  "position": "top",
  "height": 40,
  
  "modules-left": [
    "custom/access",
    "custom/terminal",
    "custom/browser",
    "hyprland/workspaces",
  ],
  
  "modules-center": [
    "clock",
    "memory",
    "cpu",
    "temperature"
  ],
  "modules-right": [
    "tray",
    "network", 
    "battery",
    "brightness",
    "custom/logout"
  ],
 /// element config 
  "custom/access": {
    "format": "ًںگ‰",
    "tooltip": false,
    "on-click":"rofi -show drun"
  },
  "custom/browser":{
    "format": "ًںگ¦â€چًں”¥",
    "on-click": "firefox",
  },
  "custom/terminal": {
    "format": ">_",
    "on-click": "kitty",
  },
  "hyprland/workspaces":{
    "format":"{icon}",
    "format-icons": {
      "1": "َ°ٹ ",
      "2": "َ°ٹ ",
      "3": "َ°ٹ ",
      "4": "َ°ٹ ",
      "5": "َ°ٹ ",
      "default": "َ°ٹ ",
      "active": "َ°®¯",
    },
    "persistent-workspaces": {
      "*": [ 1, 2, 3, 4, 5 ]
    }
  },
  "clock":{
    "interval":60,
    "format":"{:%H:%M} âŒ› ",
    "tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 4,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months":     "<span color='#ffead3'><b>{}</b></span>",
        "days":       "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
        "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
      },
    "actions":  {
      "on-click-right": "mode",
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
      }
    }
  },
  "memory": {
    "interval": 30,
    "format": "{}%َ°کڑ",
    "tooltip": true,
    "tooltip-format": "Memory Used: {used:0.1f}GiB / {total:0.1f}GiB\nSwap Used: {swapUsed:0.1f}GiB",
    "on-click": "kitty -e btop",
  },
  "cpu": {
    "interval": 30,
    "format": "{}%َ°» ",
    "tooltip": true,
    "tooltip-format": "Core0: {usage0}\nCore1: {usage1}\nCore2: {usage2}\nCore3: {usage3}\nCore4: {usage4}\nCore5: {usage5}\nCore6: {usage6}\nCore7: {usage7}",
  },
  "temperature": {
    "thermal-zone": 0,
    "interval": 30,
    "format": "{temperatureC}آ°C {icon}",
    "format-critical": "{temperatureC}آ°C {icon}",
    "format-icons": ["ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"],
    "tooltip": true,
    "critical-threshold": 80,
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "network": {
    "format": "{ifname}";
    "format-wifi": "{essid} ({signalStrength}%) ï‡«",
    "format-ethernet": "{ipaddr}/{cidr} َ°ٹ—",
    "format-disconnected": "َ±ک–",
    "tooltip-format": "{ifname} via {gwaddr} َ°ٹ—",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ï‡«",
    "tooltip-format-ethernet": "{ifname} ïƒپ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "nm-connection-editor"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% َ°‚„",
    "format-plugged": "{capacity}% ï‡¦",
    "format-alt": "{time} {icon}",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },
  "brightness": {
    "device": "intel_backlight", // Or "amdgpu_bl0" depending on your CPU
    "format": "{percent}% {icon}",
    "format-icons": ["îژچ", "îڈ“", "îڈ‘", "îڈڈ", "îڈژ", "îڈچ", "îڈٹ", "îڈˆ", "َ°›¨"],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6
  },
  "custom/logout:": {
    "format": "ًں§¨"
  }
}
